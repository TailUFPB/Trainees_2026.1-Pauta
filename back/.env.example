# Banco — dev local (docker-compose). Em prod aponte para o Postgres do Supabase.
DATABASE_URL=postgresql+psycopg://pauta:pauta@localhost:5432/pauta

# Supabase (Auth + Storage). Pegue em Project Settings > API / Database.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=dev-insecure-secret-change-me
SUPABASE_STORAGE_BUCKET=problemas

# DEVE bater com o modelo de embedding do colega da recomendação.
# Gemini text-embedding-004 = 768 | OpenAI text-embedding-3-small = 1536
EMBEDDING_DIM=768

# Chave da LLM de fotos (usada pelo colega quando ligar o serviço de visão real).
GEMINI_API_KEY=

# CORS — origem do front em dev.
CORS_ORIGINS=["http://localhost:3000"]

# Notificações
REDIS_URL=redis://localhost:6379/0
RESEND_API_KEY=re_MYueEh5g_LyDArYovAWjWgJkFogPueTAu
EMAIL_FROM=notificacoes@pauta.app
FIREBASE_CREDENTIALS_PATH=./credenciais_firebase.json
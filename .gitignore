/node_modules
client/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
client/.next/
/out/

# python / backend
__pycache__/
*.py[cod]
back/.venv/
back/uploads/
scrapers/.venv/
.ipynb_checkpoints/
.python-version

# production
/build

# misc
.DS_Store
*.pem

# brainstorming specs (locais, não versionar)
.specs/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.venv

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# Validação local (Playwright / screenshots) — não versionar
.playwright-mcp/
/recomendacoes-*.png

# Artefatos de ML gerados (regeneráveis via 'make recommendation-build') — não versionar
recommendation/models/
server/app/assets/
